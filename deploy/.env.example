# Copy to deploy/.env and fill in. docker-compose loads this into the service
# container (env_file). Every value is optional — an unset notification channel
# is simply skipped. Do NOT commit deploy/.env (it is git-ignored).

# --- nvinfer (usually leave as-is) ---
DSD_NVINFER_CONFIG=/configs/config_infer_primary.txt

# --- Notifications (Phase 8) ---
# Slack incoming webhook URL
DSD_SLACK_WEBHOOK=
# Generic webhook: structured-JSON POST endpoint
DSD_WEBHOOK_URL=
# Telegram bot token + target chat id
DSD_TELEGRAM_TOKEN=
DSD_TELEGRAM_CHAT=
# Email over SMTP
DSD_SMTP_HOST=
DSD_SMTP_PORT=587
DSD_SMTP_USER=
DSD_SMTP_PASS=
DSD_SMTP_FROM=
DSD_SMTP_TO=
